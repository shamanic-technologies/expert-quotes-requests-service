# Neon Database (expert-quotes-requests-service)
EXPERT_QUOTES_REQUESTS_SERVICE_DATABASE_URL='postgresql://...'

# Service API key (this service)
EXPERT_QUOTES_REQUESTS_SERVICE_API_KEY='your-service-api-key'

# Sentry
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Key Service (for Featured.com credentials)
KEY_SERVICE_URL='http://key-service.railway.internal'
KEY_SERVICE_API_KEY='your-key-service-api-key'

# Runs Service (mandatory run tracking)
RUNS_SERVICE_URL='https://runs.mcpfactory.org'
RUNS_SERVICE_API_KEY='your-runs-service-api-key'

# Brand Service (logo fetch for Featured profile)
BRAND_SERVICE_URL='http://brand-service.railway.internal'
BRAND_SERVICE_API_KEY='your-brand-service-api-key'

# Featured.com (fallback when key-service does not yet expose the `featured` provider)
FEATURED_USERNAME=''
FEATURED_PASSWORD=''
FEATURED_API_BASE_URL='https://featured.com/api/external-users'

# Opportunity bronze refresh TTL (ms). 5 minutes default.
FEATURED_OPPORTUNITY_TTL_MS=300000

# Server
PORT=3055
