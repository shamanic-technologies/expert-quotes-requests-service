# Neon Database (expert-quotes-requests-service)
EXPERT_QUOTES_REQUESTS_SERVICE_DATABASE_URL='postgresql://...'

# Service API key (this service)
EXPERT_QUOTES_REQUESTS_SERVICE_API_KEY='your-service-api-key'

# Sentry
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Key Service (Featured.com credentials resolved via `featured-username` and
# `featured-password` platform keys, declared by the dashboard at startup
# instrumentation — see service-architecture skill, never store external API
# keys in env vars).
KEY_SERVICE_URL='http://key-service.railway.internal'
KEY_SERVICE_API_KEY='your-key-service-api-key'

# Runs Service (mandatory run tracking)
RUNS_SERVICE_URL='https://runs.mcpfactory.org'
RUNS_SERVICE_API_KEY='your-runs-service-api-key'

# Brand Service (logo fetch for Featured profile)
BRAND_SERVICE_URL='http://brand-service.railway.internal'
BRAND_SERVICE_API_KEY='your-brand-service-api-key'

# Billing Service (credit authorization for the metered Featured pitch submit)
BILLING_SERVICE_URL='http://billing-service.railway.internal'
BILLING_SERVICE_API_KEY='your-billing-service-api-key'

# Featured/Connectively external-users API base URL (override for staging / test).
# Default = the live Connectively host. The old featured.com host is firewalled
# (429 Vercel Security Checkpoint) since the 2026-06-02 Connectively relaunch.
FEATURED_API_BASE_URL='https://www.connectively.us/api/external-users'

# Optional: pin which existing Featured profile to submit under. When unset,
# ensureFeaturedProfile auto-picks the single active, non-flagged profile from
# GET /profiles (fails loud on 0 or >1). Featured /add-profile is unusable, so
# profiles are adopted, never created. Set only if the account has >1 profile.
# FEATURED_PROFILE_ID=88890

# Opportunity bronze refresh TTL (ms). 5 minutes default.
FEATURED_OPPORTUNITY_TTL_MS=300000

# Server
PORT=3055
