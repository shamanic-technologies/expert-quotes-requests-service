{
  "openapi": "3.0.0",
  "info": {
    "title": "Expert Quotes Requests Service",
    "description": "Bronze wrapper for journalist quote-request providers (Featured.com first; HARO/SOS/Qwoted later). Owns Featured.com auth lifecycle, rate-limit budgeting, cursor / sync state, and append-only bronze raw payloads.",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://localhost:3055"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "ok"
            ]
          },
          "service": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "service"
        ]
      },
      "OpportunitiesListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FeaturedOpportunityRow"
            }
          },
          "nextSince": {
            "type": "string",
            "nullable": true
          },
          "refreshed": {
            "type": "boolean"
          }
        },
        "required": [
          "items",
          "nextSince",
          "refreshed"
        ]
      },
      "FeaturedOpportunityRow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "externalId": {
            "type": "string"
          },
          "featuredQuestionId": {
            "type": "integer",
            "nullable": true
          },
          "opportunityText": {
            "type": "string"
          },
          "mediaOutlet": {
            "type": "string",
            "nullable": true
          },
          "source": {
            "type": "string",
            "nullable": true
          },
          "pitchUrl": {
            "type": "string",
            "nullable": true
          },
          "deadline": {
            "type": "string",
            "nullable": true
          },
          "raw": {
            "nullable": true
          },
          "firstSeenAt": {
            "type": "string"
          },
          "lastSeenAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "externalId",
          "featuredQuestionId",
          "opportunityText",
          "mediaOutlet",
          "source",
          "pitchUrl",
          "deadline",
          "firstSeenAt",
          "lastSeenAt"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "OpportunityRefreshResponse": {
        "type": "object",
        "properties": {
          "refreshed": {
            "type": "boolean"
          },
          "inserted": {
            "type": "integer"
          },
          "updated": {
            "type": "integer"
          },
          "skipped": {
            "type": "integer"
          }
        },
        "required": [
          "refreshed",
          "inserted",
          "updated",
          "skipped"
        ]
      },
      "SubmissionStatusResponse": {
        "type": "object",
        "properties": {
          "statuses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SubmissionStatusEntry"
            }
          }
        },
        "required": [
          "statuses"
        ]
      },
      "SubmissionStatusEntry": {
        "type": "object",
        "properties": {
          "externalId": {
            "type": "string"
          },
          "submitted": {
            "type": "boolean"
          },
          "lastStatus": {
            "type": "string",
            "nullable": true
          },
          "submittedAt": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "externalId",
          "submitted",
          "lastStatus",
          "submittedAt"
        ]
      },
      "SubmissionStatusRequest": {
        "type": "object",
        "properties": {
          "brandId": {
            "type": "string",
            "format": "uuid"
          },
          "externalIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "maxItems": 500
          }
        },
        "required": [
          "brandId",
          "externalIds"
        ]
      },
      "SubmitAnswerResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "submitted",
              "rate_limited",
              "error"
            ]
          },
          "featuredQuestionId": {
            "type": "integer"
          },
          "featuredProfileId": {
            "type": "integer"
          },
          "retryAfter": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "InsufficientCreditResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "balance_cents": {
            "type": "number"
          },
          "required_cents": {
            "type": "number"
          }
        },
        "required": [
          "error",
          "balance_cents",
          "required_cents"
        ]
      },
      "SubmitAnswerRequest": {
        "type": "object",
        "properties": {
          "brandId": {
            "type": "string",
            "format": "uuid"
          },
          "featuredQuestionId": {
            "type": "integer"
          },
          "answer": {
            "type": "string",
            "minLength": 100,
            "maxLength": 2500
          },
          "externalId": {
            "type": "string",
            "description": "Opportunity identity (= the `externalId` from the opportunities feed) this submission is for. Persisted to the submission ledger so the authoritative submitted-status lookup can key on it."
          }
        },
        "required": [
          "brandId",
          "featuredQuestionId",
          "answer"
        ]
      },
      "ProfilesListResponse": {
        "type": "object",
        "properties": {
          "profiles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FeaturedProfileRow"
            }
          }
        },
        "required": [
          "profiles"
        ]
      },
      "FeaturedProfileRow": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "orgId": {
            "type": "string",
            "format": "uuid"
          },
          "brandId": {
            "type": "string",
            "format": "uuid"
          },
          "featuredProfileId": {
            "type": "integer"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "orgId",
          "brandId",
          "featuredProfileId",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateProfileResponse": {
        "type": "object",
        "properties": {
          "profile": {
            "$ref": "#/components/schemas/FeaturedProfileRow"
          }
        },
        "required": [
          "profile"
        ]
      },
      "CreateProfileRequest": {
        "type": "object",
        "properties": {
          "brandId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "brandId"
        ]
      },
      "DeactivateProfileResponse": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "ok"
        ]
      },
      "PremiumQuestionsResponse": {
        "type": "object",
        "properties": {
          "questions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PremiumQuestion"
            }
          },
          "refreshed": {
            "type": "boolean"
          }
        },
        "required": [
          "questions",
          "refreshed"
        ]
      },
      "PremiumQuestion": {
        "type": "object",
        "properties": {
          "featuredQuestionId": {
            "type": "integer"
          },
          "question": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "nullable": true
          },
          "mediaOutlet": {
            "type": "string",
            "nullable": true
          },
          "pitchUrl": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "nullable": true
          },
          "deadline": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "featuredQuestionId",
          "question",
          "source",
          "mediaOutlet",
          "pitchUrl",
          "createdAt",
          "deadline"
        ]
      },
      "PremiumQuestionRefreshResponse": {
        "type": "object",
        "properties": {
          "refreshed": {
            "type": "boolean"
          },
          "inserted": {
            "type": "integer"
          },
          "updated": {
            "type": "integer"
          },
          "skipped": {
            "type": "integer"
          }
        },
        "required": [
          "refreshed",
          "inserted",
          "updated",
          "skipped"
        ]
      },
      "SubmissionsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "nullable": true
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          }
        },
        "required": [
          "data"
        ]
      }
    },
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orgs/featured/opportunities": {
      "get": {
        "summary": "List bronze Featured opportunities (lazy-refreshes from Featured)",
        "description": "Lazy-refreshes from Featured if last refresh > FEATURED_OPPORTUNITY_TTL_MS. Supports cursor pagination via `?since=<ISO>` filtered against `first_seen_at`. Response carries `nextSince` for chaining.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "required": false,
            "name": "since",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 0,
              "exclusiveMinimum": true,
              "maximum": 500
            },
            "required": false,
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "When set, switches to per-brand delivery mode: returns only opportunities never delivered to this (org, brand) and records them as delivered. Consecutive calls return disjoint sets; exhausted → empty array. `nextSince` is null in this mode (the delivery ledger is the cursor). When absent, the legacy org-scoped `since` timestamp cursor is used."
            },
            "required": false,
            "description": "When set, switches to per-brand delivery mode: returns only opportunities never delivered to this (org, brand) and records them as delivered. Consecutive calls return disjoint sets; exhausted → empty array. `nextSince` is null in this mode (the delivery ledger is the cursor). When absent, the legacy org-scoped `since` timestamp cursor is used.",
            "name": "brandId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-audience-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Opportunities + cursor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpportunitiesListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Featured.com unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orgs/featured/opportunities/refresh": {
      "post": {
        "summary": "Force-refresh opportunities from Featured (bypass TTL)",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-audience-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          }
        ],
        "responses": {
          "200": {
            "description": "Refresh stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpportunityRefreshResponse"
                }
              }
            }
          },
          "502": {
            "description": "Featured.com unavailable",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orgs/featured/opportunities/submission-status": {
      "post": {
        "summary": "Authoritative submitted-status for a set of opportunities, per (org, brand)",
        "description": "Returns, for each requested `externalId`, whether it has been submitted-successfully to Featured for this (org, brand). `submitted` is true only when a ledger row with status `submitted` exists; `error`/pending/absent → `submitted: false` (still offerable, AC4). Keyed on the atomic single `brandId` + the same `externalId` the opportunities feed exposes.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-audience-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmissionStatusRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Per-opportunity submitted-status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmissionStatusResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orgs/featured/answers": {
      "post": {
        "summary": "Submit a pitch answer to a Featured question",
        "description": "Auto-ensures (org, brand) Featured profile via brand-service logo lookup. Rate-limit-aware (rolling 100 / hour per Featured account). Declares the `featured-api-pitch-submit` cost (provision → authorize → execute → actualize); the credit gate returns 402 when the org cannot afford the submit.",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-audience-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-campaign-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-feature-slug",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-workflow-slug",
            "in": "header"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitAnswerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Submission outcome",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitAnswerResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "402": {
            "description": "Insufficient credit for the featured pitch submit (credit gate). The provisioned cost is cancelled; no submit is attempted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InsufficientCreditResponse"
                }
              }
            }
          },
          "502": {
            "description": "Upstream unavailable — key-service, brand-service, billing-service, runs-service (cost provision), or Featured.com. The provisioned cost is cancelled.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/orgs/featured/profiles": {
      "get": {
        "summary": "List Featured profiles for the org (optional brandId filter)",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "brandId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "x-api-key",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": true,
            "name": "x-org-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-user-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
            "name": "x-run-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "x-brand-id",
            "in": "header"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "required": false,
